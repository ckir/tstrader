{
  "name": "tstrader",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.8",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "typecheck": "turbo run typecheck",
    "test:unit": "turbo run test:unit",
    "test:unit:bun": "turbo run test:unit:bun"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.2.0",
    "@types/node": "^24.0.0",
    "bun-types": "^1.3.8",
    "fast-check": "^4.0.0",
    "turbo": "^2.5.0",
    "typescript": "^5.9.0",
    "vitest": "^3.2.0"
  },
  "trustedDependencies": [
    "@ckirg/corelib"
  ]
}
