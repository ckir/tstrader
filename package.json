    "test:unit:bun": "turbo run test:unit:bun"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.1",
    "@types/node": "^26.0.0",
    "bun-types": "^1.3.14",
    "fast-check": "^4.8.0",
    "turbo": "^2.9.18",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "trustedDependencies": [
    "@ckirg/corelib"
  ]
}
